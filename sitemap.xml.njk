---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- for page in collections.all %}
  {%- if not page.data.excludeFromSitemap and page.url and page.url != '/README/' %}
  <url>
    <loc>https://lira.gal{{ page.url }}</loc>
    <lastmod>{{ page.date.toISOString() }}</lastmod>
    <changefreq>{{ page.data.sitemapChangefreq if page.data.sitemapChangefreq else "monthly" }}</changefreq>
    <priority>{{ page.data.sitemapPriority if page.data.sitemapPriority else "0.6" }}</priority>
  </url>
  {%- endif %}
{%- endfor %}
</urlset>
